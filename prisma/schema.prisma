generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // Opcional: las cuentas creadas con Google no tienen contraseña propia.
  passwordHash String?
  name         String
  phone        String?
  role         String   // CLIENT | WORKER | COMPANY | ADMIN
  avatarUrl    String?
  suspended    Boolean  @default(false)
  // Verificación de email: hasta tener fecha, la cuenta no puede iniciar sesión.
  emailVerified DateTime?
  // Alta con Google (OAuth). `onboarded` marca si ya eligió rol y completó el perfil.
  googleId      String?  @unique
  onboarded     Boolean  @default(true)
  createdAt    DateTime @default(now())

  workerProfile  WorkerProfile?
  companyProfile CompanyProfile?
  jobsAsClient   Job[]          @relation("ClientJobs")
  jobsAsWorker   Job[]          @relation("WorkerJobs")
  reviewsGiven   Review[]       @relation("Rater")
  reviewsGotten  Review[]       @relation("Rated")
  messages       Message[]
  conversationsA Conversation[] @relation("ConvA")
  conversationsB Conversation[] @relation("ConvB")
  reportsMade    Report[]       @relation("Reporter")
  reportsGotten  Report[]       @relation("Target")
  applications   Application[]
  posts          Post[]         @relation("PostAuthor")
  postLikes      PostLike[]
  postComments   PostComment[]
  postSaves      PostSave[]
  postReports    PostReport[]
  campaigns      Campaign[]
  authTokens     AuthToken[]
  adWallet       AdWallet?
}

/**
 * Billetera de publicidad de un trabajador o empresa.
 *
 * El saldo se carga por transferencia (WalletTopUp, aprobada por el Super
 * Admin) y se descuenta al lanzar una campaña. `spent` es el acumulado
 * histórico invertido: no se recalcula sumando campañas para que un borrado
 * futuro no altere la contabilidad.
 */
model AdWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  spent     Float    @default(0)
  createdAt DateTime @default(now())
  topUps    WalletTopUp[]
}

/** Carga de saldo por transferencia, pendiente de aprobación manual. */
model WalletTopUp {
  id         String   @id @default(cuid())
  walletId   String
  wallet     AdWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount     Float
  receiptUrl String
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note       String   @default("")
  createdAt  DateTime @default(now())
  reviewedAt DateTime?

  @@index([status, createdAt])
  @@index([walletId])
}

/**
 * Token de un solo uso para verificar el email (y, más adelante, para
 * restablecer la contraseña). Se borra al usarse o al vencer.
 */
/**
 * Registro de un pago entre cliente y trabajador.
 *
 * Better Work NO recibe ni retiene este dinero: el cliente le transfiere
 * directamente al profesional. La app sólo deja constancia de que el pago se
 * hizo y de que la otra parte lo reconoció, para que quede un historial y para
 * habilitar los pasos del trabajo.
 *
 * Son dos por trabajo:
 *   - DEPOSIT: la seña, antes de empezar. Compromete a las dos partes.
 *   - FINAL:   el saldo, cuando el trabajo terminó.
 *
 * Estados: SENT (el cliente dice que transfirió) → CONFIRMED (el trabajador
 * confirma que lo recibió). Sin CONFIRMED de la seña el trabajo no arranca.
 */
/**
 * Presupuesto que el trabajador le envía al cliente antes del pago.
 *
 * El cliente lo acepta (fija el precio del trabajo y pasa a ACCEPTED), lo
 * rechaza, o pide cambios (CHANGES) y el trabajador manda uno nuevo. El más
 * reciente es el vigente; los anteriores quedan como historial.
 */
model Quote {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  price         Float
  estimatedTime String   @default("") // ej. "2 días", "1 semana"
  note          String   @default("") // observaciones del trabajador
  status        String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | CHANGES
  clientNote    String   @default("") // qué pidió cambiar el cliente
  createdAt     DateTime @default(now())

  @@index([jobId, createdAt])
}

model Payment {
  id          String   @id @default(cuid())
  jobId       String   @unique
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  amount      Float    // total del trabajo que paga el cliente
  commission  Float    @default(0) // comisión de Better Work, calculada al liberar
  status      String   @default("PENDING") // PENDING | HELD | RELEASED | REFUNDED
  method      String   @default("simulated") // id del proveedor (mercadopago | simulated)
  providerRef String? // id de la operación en el proveedor
  createdAt   DateTime @default(now())
  heldAt      DateTime?
  releasedAt  DateTime?
  refundedAt  DateTime?

  @@index([status])
}

model AuthToken {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // EMAIL_VERIFY
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/**
 * Solicitud de membresía pagada por transferencia.
 *
 * La empresa elige el plan, transfiere y sube el comprobante; queda PENDING
 * hasta que el Super Admin la aprueba (recién ahí se activa el plan) o la
 * rechaza. Guarda el precio del momento para que un cambio de tarifa no
 * altere una solicitud ya enviada.
 */
model PlanRequest {
  id         String   @id @default(cuid())
  companyId  String
  company    CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planKey    String
  amount     Float
  days       Int      @default(30)
  receiptUrl String
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note       String   @default("")
  createdAt  DateTime @default(now())
  reviewedAt DateTime?

  @@index([status, createdAt])
  @@index([companyId])
}

/**
 * Planes de membresía para empresas (los trabajadores son siempre gratis).
 * Totalmente configurables desde el panel Super Admin: precio, límites y
 * beneficios. Agregar un beneficio nuevo = una columna acá + su chequeo.
 */
model Plan {
  key             String  @id // STARTER | BUSINESS | ENTERPRISE
  name            String
  tagline         String  @default("")
  price           Float
  order           Int     @default(0)
  active          Boolean @default(true)
  // Límites (-1 = ilimitado)
  jobPostLimit    Int     @default(3) // ofertas activas simultáneas
  applicantLimit  Int     @default(10) // postulaciones visibles por oferta
  // Beneficios
  searchBoost     Float   @default(0) // posicionamiento extra en listados
  analytics       Boolean @default(false) // dashboard de estadísticas
  verifiedBadge   Boolean @default(false) // insignia verificada automática
  featuredHome    Boolean @default(false) // aparece destacada en el inicio
  prioritySupport Boolean @default(false)
  companies       CompanyProfile[]
}

/**
 * Campaña publicitaria: el usuario define presupuesto, duración, objetivo y
 * alcance. La app calcula el empuje en los listados y mide el rendimiento.
 */
model Campaign {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  target      String // WORKER | COMPANY
  objective   String // VISIBILITY | REQUESTS | REPUTATION
  reach       String // ZONE | CITY | PROVINCE
  budget      Float
  days        Int
  dailyBudget Float
  boost       Float // empuje calculado en el ranking
  status      String   @default("ACTIVE") // ACTIVE | FINISHED | CANCELLED
  startedAt   DateTime @default(now())
  endsAt      DateTime
  // Métricas medidas (las solicitudes y trabajos se derivan por fecha)
  impressions Int      @default(0) // veces que apareció en listados
  views       Int      @default(0) // veces que abrieron el perfil
  clicks      Int      @default(0) // clics en la tarjeta patrocinada
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model WorkerProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession   String
  bio          String    @default("")
  experience   Int       @default(0) // años
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  services     String    @default("[]") // JSON string[]
  gallery      String    @default("[]") // JSON string[] (urls)
  city         String    @default("")
  zone         String    @default("")
  lat          Float?
  lng          Float?
  radiusKm     Float     @default(10) // 5/10/20/50, 100=ciudad, 500=provincia
  schedule     String    @default("") // rango horario ej "08:00-18:00"
  availableDays String   @default("[]") // JSON string[] ej ["Lun","Mar","Mie"]
  workMode     String    @default("AMBOS") // ONSITE | REMOTE | AMBOS
  whatsapp     String?
  payMethods   String    @default("[]") // JSON string[] ej ["Efectivo","Transferencia","Mercado Pago"]
  // Datos de cobro: el cliente le transfiere directamente a este alias.
  payAlias     String?
  payHolder    String?
  priceHint    String? // precios orientativos (opcional)
  verified     Boolean   @default(false)
  visible      Boolean   @default(true)
  // Publicidad (denormalizado desde la campaña activa, para el ranking)
  sponsoredUntil DateTime?
  sponsorBoost Float     @default(0)
  // Métricas
  profileViews      Int  @default(0) // veces que abrieron el perfil
  searchAppearances Int  @default(0) // veces que apareció en listados
  jobsDone     Int       @default(0)
  ratingAvg    Float     @default(0)
  ratingCount  Int       @default(0)
  cancellations Int      @default(0)
  // Señales del rango (denormalizadas para que los listados sean baratos)
  punctualityAvg  Float  @default(0) // promedio de puntualidad de las reseñas
  avgResponseMins Int? // minutos promedio en aceptar/rechazar una solicitud
  claims          Int    @default(0) // denuncias recibidas
  createdAt    DateTime  @default(now())
}

model CompanyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  description String   @default("")
  industry    String   @default("")
  city        String   @default("")
  lat         Float?
  lng         Float?
  website     String?
  verified    Boolean  @default(false)
  // Membresía: sin plan activo la empresa no publica ni aparece
  planKey         String?
  plan            Plan?     @relation(fields: [planKey], references: [key])
  planActiveUntil DateTime?
  // Publicidad
  sponsoredUntil  DateTime?
  sponsorBoost    Float    @default(0)
  profileViews    Int      @default(0)
  createdAt   DateTime @default(now())
  offers      JobOffer[]
  planRequests PlanRequest[]
}

model Category {
  id      String @id @default(cuid())
  name    String @unique
  slug    String @unique
  icon    String @default("🔧")
  order   Int    @default(0)
  active  Boolean @default(true)
  workers WorkerProfile[]
  offers  JobOffer[]
}

model Job {
  id           String    @id @default(cuid())
  clientId     String
  client       User      @relation("ClientJobs", fields: [clientId], references: [id])
  workerId     String
  worker       User      @relation("WorkerJobs", fields: [workerId], references: [id])
  title        String
  description  String    @default("")
  address      String    @default("")
  lat          Float?
  lng          Float?
  scheduledFor DateTime?
  price        Float? // total acordado del trabajo (retenido por Better Work)
  status       String    @default("REQUESTED") // REQUESTED|ACCEPTED|EN_ROUTE|WORKING|COMPLETED|CANCELLED|REJECTED
  startCode    String?
  endCode      String?
  requestedAt  DateTime  @default(now())
  acceptedAt   DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  reviews      Review[]
  payment      Payment?
  quotes       Quote[]

  @@index([workerId, requestedAt])
  @@index([clientId])
}

model Review {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id])
  raterId       String
  rater         User     @relation("Rater", fields: [raterId], references: [id])
  ratedId       String
  rated         User     @relation("Rated", fields: [ratedId], references: [id])
  stars         Int
  punctuality   Int      @default(0)
  quality       Int      @default(0)
  communication Int      @default(0)
  compliance    Int      @default(0)
  comment       String   @default("")
  createdAt     DateTime @default(now())

  @@unique([jobId, raterId])
}

model Conversation {
  id        String    @id @default(cuid())
  aId       String
  a         User      @relation("ConvA", fields: [aId], references: [id])
  bId       String
  b         User      @relation("ConvB", fields: [bId], references: [id])
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
  messages  Message[]

  @@unique([aId, bId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  type           String       @default("TEXT") // TEXT|IMAGE|LOCATION|FILE|BUDGET
  content        String       @default("")
  meta           String       @default("{}") // JSON: {url, lat, lng, amount, filename...}
  readAt         DateTime?
  createdAt      DateTime     @default(now())
}

model JobOffer {
  id          String         @id @default(cuid())
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  description String         @default("")
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  city        String         @default("")
  modality    String         @default("Presencial") // Presencial | Remoto | Híbrido
  salary      String?
  promotedUntil DateTime?
  views       Int            @default(0) // visualizaciones de la publicación
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  applications Application[]
}

model Application {
  id        String   @id @default(cuid())
  offerId   String
  offer     JobOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  workerId  String
  worker    User     @relation(fields: [workerId], references: [id])
  message   String   @default("")
  status    String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt DateTime @default(now())

  @@unique([offerId, workerId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  targetId   String
  target     User     @relation("Target", fields: [targetId], references: [id])
  reason     String
  status     String   @default("OPEN") // OPEN | RESOLVED | DISMISSED
  createdAt  DateTime @default(now())
}

/**
 * Compra registrada: membresía de empresa o campaña publicitaria.
 * El cobro se arregla fuera de la app (todavía no hay pasarela de pagos);
 * esto es el libro de ingresos que ve el panel Super Admin.
 */
model Promotion {
  id        String   @id @default(cuid())
  userId    String // quién compró
  kind      String   // COMPANY_PLAN | CAMPAIGN
  refId     String   // id del plan o de la campaña
  days      Int
  amount    Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/**
 * Feed social profesional. Cualquier usuario publica. Las imágenes se guardan
 * como JSON de URLs (subidas reales a /uploads). `hidden` es para moderación.
 */
model Post {
  id            String   @id @default(cuid())
  authorId      String
  author        User     @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content       String   @default("")
  kind          String   @default("GENERAL") // GENERAL|WORK_DONE|BEFORE_AFTER|PROMO|HIRING|JOB_SEEK|TIP|NEWS
  images        String   @default("[]") // JSON string[] de URLs
  lat           Float?
  lng           Float?
  locationLabel String   @default("")
  sponsoredUntil DateTime?
  hidden        Boolean  @default(false) // oculto por moderación
  shareCount    Int      @default(0)
  createdAt     DateTime @default(now())

  likes    PostLike[]
  comments PostComment[]
  saves    PostSave[]
  reports  PostReport[]

  @@index([createdAt])
  @@index([authorId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model PostSave {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostReport {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  status     String   @default("OPEN") // OPEN | RESOLVED | DISMISSED
  createdAt  DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
