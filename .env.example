# Better Work — variables de entorno
# Copiá este archivo como .env (local) o cargalas en Vercel (producción).

# ── Base de datos (PostgreSQL / Supabase) ────────────────────────────────
# Supabase → Project Settings → Database → Connection string → "Transaction pooler"
# Acordate de reemplazar [YOUR-PASSWORD] por la contraseña de la base.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ── Sesiones ─────────────────────────────────────────────────────────────
# Obligatorio en producción. Generalo con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# ── Supabase Storage (fotos de perfil, galerías y feed) ───────────────────
# Si faltan, la app guarda las imágenes en /public/uploads (solo sirve en local).
NEXT_PUBLIC_SUPABASE_URL="https://oulwejxaorrosqlexnnz.supabase.co"
# Supabase → Project Settings → API Keys → service_role (SECRETA, nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# ── URL pública (OG, robots, sitemap, retorno de pagos) ──────────────────
NEXT_PUBLIC_SITE_URL="https://tu-dominio.vercel.app"

# ── Inicio de sesión con Google (opcional) ───────────────────────────────
# Sin estas variables, el botón de Google no se muestra y el resto sigue igual.
# Google Cloud Console → APIs y servicios → Credenciales → ID de cliente OAuth
# (tipo "Aplicación web"). En "URI de redirección autorizados" agregá:
#   http://localhost:3001/api/auth/google/callback   (desarrollo)
#   https://TU-DOMINIO/api/auth/google/callback      (producción)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Envío de emails (opcional pero recomendado) ──────────────────────────
# Sin proveedor, la app NO envía el email de verificación: muestra el enlace en
# pantalla para poder confirmar la cuenta en desarrollo.
# Crear la API key en https://resend.com → API Keys
RESEND_API_KEY=
# Remitente. Debe ser un dominio verificado en el proveedor.
MAIL_FROM="Better Work <no-reply@tu-dominio.com>"
